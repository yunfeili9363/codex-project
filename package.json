{
  "name": "telegram-codex-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "service:install": "bash scripts/install-launchd.sh",
    "service:uninstall": "bash scripts/uninstall-launchd.sh",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx src/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
